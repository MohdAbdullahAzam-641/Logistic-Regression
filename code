    x='Statement_Match_Score', bins=15, color=colors['Rejected'], ax=axes[1], kde=True
)
axes[1].set_title('Graph 2: Rejected Claims', fontsize=14, weight='bold')
axes[1].set_xlabel('Statement Match %')

# Graph 3: Pending Review
