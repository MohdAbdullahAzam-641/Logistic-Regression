# Combine and tag
four_wheelers_tagged = [f"{v} (4-Wheeler)" for v in four_wheelers]
two_wheelers_tagged = [f"{v} (2-Wheeler)" for v in two_wheelers]
master_vehicle_fleet = four_wheelers_tagged + two_wheelers_tagged

# STEP 2: Generate Dataset (2,500 Claims)
np.random.seed(42)
total_claims = 2500

customer_vehicles = np.random.choice(master_vehicle_fleet, total_claims)
statement_match_percentage = np.random.randint(40, 100, total_claims)
warranty_voided = np.random.choice([0, 1], total_claims, p=[0.85, 0.15])

# Base Training Logic
claims_approved = [
    1 if (match > 75 and void == 0) else 0
    for match, void in zip(statement_match_percentage, warranty_voided)
]

insurance_data = pd.DataFrame({
    'Vehicle_Model': customer_vehicles,
    'Statement_Match_Score': statement_match_percentage,
    'Warranty_Voided_Flag': warranty_voided,
    'Claim_Approved': claims_approved
})

# STEP 3: Train the Model
features = insurance_data[['Statement_Match_Score', 'Warranty_Voided_Flag']]
target = insurance_data['Claim_Approved']

# Use 1000 claims as our "Test Desk" to generate meaningful graphs
X_train, X_test, y_train, y_test = train_test_split(features, target, test_size=1000, random_state=42)

ai_adjuster = LogisticRegression()
ai_adjuster.fit(X_train, y_train)

# STEP 4: Apply Probability Logic for 3 Categories
# Get the percentage confidence of a claim being Approved (Class 1)
probabilities = ai_adjuster.predict_proba(X_test)[:, 1]

final_decisions = []
for prob in probabilities:
    if prob >= 0.70:
        final_decisions.append('Accepted')
    elif prob <= 0.40:
        final_decisions.append('Rejected')
    else:
        final_decisions.append('Pending Review')

# Attach decisions to our test data for plotting
test_results = X_test.copy()
test_results['AI_Decision'] = final_decisions

# STEP 5: Generate the 3 Graphs
sns.set_theme(style="whitegrid")
fig, axes = plt.subplots(1, 3, figsize=(18, 5), sharey=True)
fig.suptitle('Insurance Claim AI Processing Desk: Statement Match Score vs Decisions', fontsize=16, weight='bold')

colors = {'Accepted': '#2ecc71', 'Rejected': '#e74c3c', 'Pending Review': '#f1c40f'}

# Graph 1: Accepted
sns.histplot(
    data=test_results[test_results['AI_Decision'] == 'Accepted'],
    x='Statement_Match_Score', bins=15, color=colors['Accepted'], ax=axes[0], kde=True
)
axes[0].set_title('Graph 1: Accepted Claims', fontsize=14, weight='bold')
axes[0].set_xlabel('Statement Match %')
axes[0].set_ylabel('Number of Claims')

# Graph 2: Rejected
